{
  "name": "asciidoc-testkit",
  "private": true,
  "description": "A toolkit for testing AsciiDoc converters/backends against a shared corpus of input/output fixtures, from JavaScript or any language via a native CLI.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ggrossetie/asciidoc-testkit.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "node --test test/*.test.js && npm test --workspaces --if-present",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.5.5"
  }
}
