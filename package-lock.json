{
  "name": "asciidoc-testkit",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "asciidoc-testkit",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@asciidoc-testkit/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@asciidoc-testkit/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/asciidoc-testkit": {
      "resolved": "packages/js-lib",
      "link": true
    },
    "packages/cli": {
      "name": "@asciidoc-testkit/cli",
      "version": "0.0.0",
      "license": "MIT",
      "dependencies": {
        "@asciidoc-testkit/core": "0.0.0"
      },
      "bin": {
        "asciidoc-testkit": "src/cli.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/core": {
      "name": "@asciidoc-testkit/core",
      "version": "0.0.0",
      "license": "MIT",
      "engines": {
        "node": ">=20"
      }
    },
    "packages/js-lib": {
      "name": "asciidoc-testkit",
      "version": "0.0.0",
      "license": "MIT",
      "dependencies": {
        "@asciidoc-testkit/core": "0.0.0"
      },
      "engines": {
        "node": ">=20"
      }
    }
  }
}
