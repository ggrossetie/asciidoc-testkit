{
  "name": "asciidoc-testkit-cli",
  "version": "0.1.2",
  "description": "CLI to run the asciidoc-testkit fixture corpus against any converter (Ruby, Rust, Java, ...) invoked as an external command. Also available as a standalone native binary.",
  "type": "module",
  "bin": {
    "asciidoc-testkit": "src/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ggrossetie/asciidoc-testkit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ggrossetie/asciidoc-testkit/tree/main/packages/cli#readme",
  "bugs": "https://github.com/ggrossetie/asciidoc-testkit/issues",
  "dependencies": {
    "asciidoc-testkit-core": "0.1.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "postject": "^1.0.0-alpha.6"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "build:sea": "node tasks/sea/build.js"
  },
  "license": "MIT"
}
